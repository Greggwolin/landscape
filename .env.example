# Landscape — Next.js env var template
#
# Copy to .env.local and fill in real values. Do NOT commit .env.local
# (it's gitignored). This file lists every env var the app expects.

# Database Connection (Neon PostgreSQL, land_v2 database)
DATABASE_URL=

# Django Backend API URL
# Development:  http://localhost:8000
# Production:   https://<your-railway-subdomain>.up.railway.app
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8000
DJANGO_API_URL=http://localhost:8000

# JWT signature verification (Bug 5 fix, 2026-04-06)
# REQUIRED. Must match Django's SECRET_KEY exactly — getUserFromRequest in
# src/lib/auth.ts uses this to verify HS256-signed simplejwt access tokens.
# If unset, the Next.js app will fail at boot with an explicit error.
#
# Rollout:
#   - Local:       set to the value in backend/.env SECRET_KEY
#   - Vercel:      set on prod and preview, must equal Railway SECRET_KEY
#   - Railway:     no change — Django already uses SECRET_KEY directly
JWT_SIGNING_KEY=

# Third-party services
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
UPLOADTHING_TOKEN=

# Optional — Crisp chat widget
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Optional — Zillow property search
# ZILLOW_API_BASE_URL=https://api.zillow.com
# ZILLOW_API_KEY=
