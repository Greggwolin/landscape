# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.template

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Large files and local development files
*.zip
*.tar.gz
*.sql
/LocalFiles/

# Office temp files
~$*

# Claude session data
.claude/plans/
.claude/scheduled_tasks.lock
/.vscode/
*.psd
*.DS_Store

# AI chat exports
docs/ai-chats/*.png
docs/ai-chats/*.zip

# Development containers
.devcontainer/.env
docker-compose.override.yml
# Large GIS files
src/app/GIS/*.shp
src/app/GIS/*.dbf
src/app/GIS/*.shx
src/app/GIS/*.sbn
src/app/GIS/*.sbx
public/pinal_parcels.geojson
data/external/**/*.geojson
data/external/**/*.zip
data/external/**/*.shp
data/external/**/*.dbf
data/external/**/*.shx
data/external/**/*.sbn
data/external/**/*.sbx
data/external/**/*.prj
data/external/**/*.cpg
data/external/**/*.gpkg
data/external/**/*.sqlite
data/external/**/*.mbtiles
data/external/**/*.parquet
!data/external/**/.gitkeep
!data/external/**/*.md

# Temporary backups
*_backup
*.backup
*.old
*.old2

# Backend uploads and media (user data should not be committed)
backend/uploads/
backend/media/

# Test/debug data files
backend/*_extraction.json
backend/*_reconciliation_report.md
backend/*_rent_roll_extracted.json

# Python cache and bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
backend/**/__pycache__/
backend/**/migrations/__pycache__/
services/**/__pycache__/

# Virtual environments
.venv/
venv/
services/**/.venv/

# Archive and backup directories
backup_*/

# Archive - track docs but ignore large GIS data
archive/gis-data/**/*.dbf
archive/gis-data/**/*.shp
archive/gis-data/**/*.shx
archive/gis-data/**/*.prj
archive/gis-data/**/*.sbn
archive/gis-data/**/*.sbx
archive/gis-data/**/*.cpg
archive/gis-data/**/*.geojson
archive/gis-data/**/*.zip
!archive/gis-data/.gitkeep
!archive/docs/
!archive/scripts/
!archive/migrations-legacy/

# Temporary working files (scratch/throwaway only)
tmp_*
test-results/
.next_stale*
.next_stale_*
landscape_rich_schema_*.json

# Playwright MCP artifacts
.playwright-mcp/

# Session / smoke-test logs
cowork-session-logs/
smoke-test-*.md
Smoke_Test_*.md
/P2_TOOL_TEST_REPORT.md
/Document_Ingestion_Modal_Discovery_Audit.md

# Throwaway debug / one-off scripts
check-fk.js
scripts/delete-proj-*.js
scripts/delete-project-*.js
scripts/check-*.js
scripts/debug-*.js
scripts/list-projects.js
scripts/verify-deletion.js

# Screenshots & screen recordings (keep local only)
reference/images/screenshots/*.mov
reference/images/screenshots/*.mp4
reference/images/screenshots/*.png

# Large reference materials (keep local only — too large for GitHub)
reference/landdev/

# Rent schedule debug images
rent-schedule-*.png

# Claude local settings (machine-specific)
.claude/settings.local.json
.aider*
broken_uploadthing_urls_report.txt
uploadthing_url_check.csv
reference/images/screenshots/Untitled.jpg

# Agent framework calibration run reports (per-run output, not baselines)
tests/agent_framework/reports/

# Claude Code worktree orphans (registered via `git worktree` — files live under .git/worktrees/)
.claude/worktrees/

# Local test fixtures (not shared)
test-docs/

# Spent deploy-prompt scratch docs (historical, kept local)
CC_*.md
