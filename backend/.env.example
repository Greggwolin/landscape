# PostgreSQL connection string for the app database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# Django secret key used for cryptographic signing
SECRET_KEY=change-me-to-a-long-random-string

# Debug mode for Django (use False in production)
DEBUG=False

# Comma-separated allowed hostnames (include Railway wildcard if needed)
ALLOWED_HOSTS=example.com,.railway.app

# Discord webhook URL for Landscaper chat feedback capture
# Messages containing #FB will be forwarded here with context for alpha testing
LANDSCAPER_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
